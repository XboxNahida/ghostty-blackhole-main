 {
     "version": "0.2.0",
     "configurations": [
         {
             "name": "Debug (F5)",
             "type": "cppdbg",
             "request": "launch",
             "program": "${workspaceFolder}/build/blackhole.exe",
             "args": [],
             "cwd": "${workspaceFolder}",
             "preLaunchTask": "build-debug",
             "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
             "externalConsole": true,
             "MIMode": "gdb",
             "setupCommands": [
                 {
                     "description": "Enable pretty printing for gdb",
                     "text": "-enable-pretty-printing",
                     "ignoreFailures": true
                 }
             ],
             "presentation": {
                 "group": "cpp",
                 "order": 1
             }
         },
         {
             "name": "Run (Ctrl+F5)",
             "type": "cppdbg",
             "request": "launch",
             "program": "${workspaceFolder}/build/blackhole.exe",
             "args": [],
             "cwd": "${workspaceFolder}",
             "preLaunchTask": "build-release",
             "externalConsole": false,
             "MIMode": "gdb",
             "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
             "presentation": {
                 "group": "cpp",
                 "order": 2
             }
         }
     ]
 }
